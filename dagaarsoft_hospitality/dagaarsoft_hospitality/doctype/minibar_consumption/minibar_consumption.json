{
  "name": "Minibar Consumption",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "MBR-.YYYY.-.####\n",
      "reqd": 1
    },
    {
      "fieldname": "property",
      "fieldtype": "Link",
      "label": "Property",
      "options": "Property",
      "reqd": 1
    },
    {
      "fieldname": "guest_stay",
      "fieldtype": "Link",
      "label": "Guest Stay",
      "options": "Guest Stay",
      "reqd": true,
      "in_list_view": 1
    },
    {
      "fieldname": "room",
      "fieldtype": "Link",
      "label": "Room",
      "options": "Room",
      "fetch_from": "guest_stay.room",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "minibar_items",
      "fieldtype": "Table",
      "label": "Items",
      "options": "Minibar Consumption Item"
    },
    {
      "fieldname": "total_amount",
      "fieldtype": "Currency",
      "label": "Total Amount",
      "read_only": 1
    },
    {
      "fieldname": "charge_to_folio",
      "fieldtype": "Check",
      "label": "Charge to Folio",
      "default": "1"
    },
    {
      "fieldname": "folio_charge_posted",
      "fieldtype": "Check",
      "label": "Folio Charge Posted",
      "read_only": 1
    }
  ],
  "permissions": [
    {
      "role": "Hotel Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Hotel Receptionist",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    }
  ]
}