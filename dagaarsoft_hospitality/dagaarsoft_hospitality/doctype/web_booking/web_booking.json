{
  "name": "Web Booking",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"WEB-.YYYY.-.####\n","reqd":1},
    {"fieldname":"property","fieldtype":"Link","label":"Property","options":"Property","reqd":1},
    {"fieldname":"booking_status","fieldtype":"Select","label":"Status",
      "options":"Pending\nConfirmed\nConverted\nCancelled\nExpired",
      "default":"Pending","in_list_view":1,"in_standard_filter":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"booking_token","fieldtype":"Data","label":"Booking Token","read_only":1},
    {"fieldname":"submitted_on","fieldtype":"Datetime","label":"Submitted On","read_only":1},
    {"fieldname":"ip_address","fieldtype":"Data","label":"IP Address","read_only":1},
    {"fieldname":"sec_guest","fieldtype":"Section Break","label":"Guest Information"},
    {"fieldname":"guest_first_name","fieldtype":"Data","label":"First Name","reqd":1},
    {"fieldname":"guest_last_name","fieldtype":"Data","label":"Last Name","reqd":1},
    {"fieldname":"guest_email","fieldtype":"Data","label":"Email","reqd":1},
    {"fieldname":"guest_phone","fieldtype":"Data","label":"Phone","reqd":1},
    {"fieldname":"col2","fieldtype":"Column Break"},
    {"fieldname":"guest_nationality","fieldtype":"Data","label":"Nationality"},
    {"fieldname":"id_type","fieldtype":"Select","label":"ID Type",
      "options":"\nPassport\nNational ID\nDriving License"},
    {"fieldname":"id_number","fieldtype":"Data","label":"ID Number"},
    {"fieldname":"special_requests","fieldtype":"Text","label":"Special Requests"},
    {"fieldname":"sec_stay","fieldtype":"Section Break","label":"Stay Details"},
    {"fieldname":"room_type","fieldtype":"Link","label":"Room Type","options":"Room Type","reqd":1},
    {"fieldname":"arrival_date","fieldtype":"Date","label":"Check-In","reqd":1},
    {"fieldname":"departure_date","fieldtype":"Date","label":"Check-Out","reqd":1},
    {"fieldname":"num_nights","fieldtype":"Int","label":"Nights","read_only":1},
    {"fieldname":"col3","fieldtype":"Column Break"},
    {"fieldname":"adults","fieldtype":"Int","label":"Adults","default":"1","reqd":1},
    {"fieldname":"children","fieldtype":"Int","label":"Children","default":"0"},
    {"fieldname":"meal_plan","fieldtype":"Select","label":"Meal Plan",
      "options":"Room Only\nBed & Breakfast\nHalf Board\nFull Board\nAll Inclusive"},
    {"fieldname":"rate_plan","fieldtype":"Link","label":"Rate Plan","options":"Rate Plan"},
    {"fieldname":"sec_pricing","fieldtype":"Section Break","label":"Pricing"},
    {"fieldname":"nightly_rate","fieldtype":"Currency","label":"Nightly Rate","read_only":1},
    {"fieldname":"total_amount","fieldtype":"Currency","label":"Total Amount","read_only":1},
    {"fieldname":"deposit_required","fieldtype":"Currency","label":"Deposit Required","read_only":1},
    {"fieldname":"col4","fieldtype":"Column Break"},
    {"fieldname":"currency","fieldtype":"Link","label":"Currency","options":"Currency"},
    {"fieldname":"promo_code","fieldtype":"Data","label":"Promo Code"},
    {"fieldname":"discount_applied","fieldtype":"Currency","label":"Discount Applied","read_only":1},
    {"fieldname":"sec_payment","fieldtype":"Section Break","label":"Payment"},
    {"fieldname":"payment_status","fieldtype":"Select","label":"Payment Status",
      "options":"Unpaid\nDeposit Paid\nFully Paid","default":"Unpaid","in_list_view":1},
    {"fieldname":"payment_reference","fieldtype":"Data","label":"Payment Reference"},
    {"fieldname":"col5","fieldtype":"Column Break"},
    {"fieldname":"hotel_deposit","fieldtype":"Link","label":"Deposit Record","options":"Hotel Deposit","read_only":1},
    {"fieldname":"sec_conversion","fieldtype":"Section Break","label":"Conversion"},
    {"fieldname":"reservation","fieldtype":"Link","label":"Reservation","options":"Reservation","read_only":1},
    {"fieldname":"customer","fieldtype":"Link","label":"Customer","options":"Customer","read_only":1},
    {"fieldname":"converted_by","fieldtype":"Link","label":"Converted By","options":"User","read_only":1},
    {"fieldname":"converted_on","fieldtype":"Datetime","label":"Converted On","read_only":1},
    {"fieldname":"cancellation_reason","fieldtype":"Text","label":"Cancellation Reason"},
    {"fieldname":"amended_from","fieldtype":"Link","label":"Amended From","options":"Web Booking","print_hide":1}
  ],
  "permissions": [
    {"role":"Hotel Manager","read":1,"write":1,"create":1,"submit":1,"cancel":1,"amend":1,"delete":1},
    {"role":"Hotel Receptionist","read":1,"write":1,"create":1,"submit":1},
    {"role":"Guest","read":1}
  ]
}
