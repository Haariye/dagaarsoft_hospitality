{
  "name": "Restaurant Bill",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "RBL-.YYYY.-.####\n",
      "reqd": 1
    },
    {
      "fieldname": "property",
      "fieldtype": "Link",
      "label": "Property",
      "options": "Property",
      "reqd": 1
    },
    {
      "fieldname": "outlet",
      "fieldtype": "Link",
      "label": "Outlet",
      "options": "Outlet"
    },
    {
      "fieldname": "bill_date",
      "fieldtype": "Date",
      "label": "Bill Date",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "customer",
      "fieldtype": "Link",
      "label": "Customer",
      "options": "Customer"
    },
    {
      "fieldname": "charge_to_room",
      "fieldtype": "Check",
      "label": "Charge to Room"
    },
    {
      "fieldname": "guest_stay",
      "fieldtype": "Link",
      "label": "Guest Stay",
      "options": "Guest Stay",
      "depends_on": "eval:doc.charge_to_room"
    },
    {
      "fieldname": "bill_items",
      "fieldtype": "Table",
      "label": "Items",
      "options": "Restaurant Bill Item"
    },
    {
      "fieldname": "sec_totals",
      "fieldtype": "Section Break",
      "label": "Totals"
    },
    {
      "fieldname": "total_amount",
      "fieldtype": "Currency",
      "label": "Total Amount",
      "read_only": 1
    },
    {
      "fieldname": "paid_amount",
      "fieldtype": "Currency",
      "label": "Paid Amount"
    },
    {
      "fieldname": "payment_mode",
      "fieldtype": "Select",
      "label": "Payment Mode",
      "options": "Cash\nCard\nRoom Charge\nComplimentary"
    },
    {
      "fieldname": "pos_invoice",
      "fieldtype": "Link",
      "label": "POS Invoice",
      "options": "POS Invoice",
      "read_only": 1
    },
    {
      "fieldname": "sales_invoice",
      "fieldtype": "Link",
      "label": "Sales Invoice",
      "options": "Sales Invoice",
      "read_only": 1
    },
    {
      "fieldname": "notes",
      "fieldtype": "Text",
      "label": "Notes"
    }
  ],
  "permissions": [
    {
      "role": "Hotel Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Restaurant Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    }
  ]
}