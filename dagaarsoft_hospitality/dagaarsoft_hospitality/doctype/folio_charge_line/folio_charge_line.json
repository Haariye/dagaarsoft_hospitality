{
  "name": "Folio Charge Line",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "istable": 1,
  "editable_grid": 0,
  "fields": [
    {
      "fieldname": "posting_date",
      "fieldtype": "Date",
      "label": "Date",
      "reqd": 1,
      "in_list_view": 1,
      "default": "Today",
      "read_only": 1
    },
    {
      "fieldname": "posting_time",
      "fieldtype": "Time",
      "label": "Time",
      "read_only": 1
    },
    {
      "fieldname": "charge_category",
      "fieldtype": "Select",
      "label": "Category",
      "in_list_view": 1,
      "options": "Room Rate\nRestaurant\nMinibar\nF&B\nLaundry\nTransport\nBanquet\nSpa\nTelephone\nMiscellaneous\nTax\nDiscount\nAdjustment",
      "reqd": 1,
      "read_only": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Data",
      "label": "Description",
      "reqd": 1,
      "in_list_view": 1,
      "read_only": 1
    },
    {
      "fieldname": "qty",
      "fieldtype": "Float",
      "label": "Qty",
      "default": "1",
      "in_list_view": 1,
      "read_only": 1
    },
    {
      "fieldname": "rate",
      "fieldtype": "Currency",
      "label": "Rate",
      "in_list_view": 1,
      "read_only": 1
    },
    {
      "fieldname": "amount",
      "fieldtype": "Currency",
      "label": "Amount",
      "read_only": 1,
      "in_list_view": 1,
      "bold": 1
    },
    {
      "fieldname": "outlet",
      "fieldtype": "Link",
      "label": "Outlet",
      "options": "Outlet",
      "read_only": 1
    },
    {
      "fieldname": "guest_stay",
      "fieldtype": "Link",
      "label": "Guest Stay",
      "options": "Guest Stay",
      "read_only": 1
    },
    {
      "fieldname": "reference_doctype",
      "fieldtype": "Link",
      "label": "Ref DocType",
      "options": "DocType",
      "read_only": 1
    },
    {
      "fieldname": "reference_name",
      "fieldtype": "Dynamic Link",
      "label": "Ref Name",
      "options": "reference_doctype",
      "read_only": 1
    },
    {
      "fieldname": "posted_by",
      "fieldtype": "Link",
      "label": "Posted By",
      "options": "User",
      "read_only": 1
    },
    {
      "fieldname": "is_void",
      "fieldtype": "Check",
      "label": "Void",
      "default": "0",
      "read_only": 1
    },
    {
      "fieldname": "void_reason",
      "fieldtype": "Data",
      "label": "Void Reason",
      "depends_on": "eval:doc.is_void",
      "read_only": 1
    },
    {
      "fieldname": "is_billed",
      "fieldtype": "Check",
      "label": "Billed",
      "default": "0",
      "read_only": 1,
      "description": "Set when included in a Sales Invoice"
    }
  ]
}