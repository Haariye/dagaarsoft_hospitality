{
  "name": "Transport Booking",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "fields": [
    {
      "fieldname": "naming_series",
      "fieldtype": "Select",
      "label": "Naming Series",
      "options": "TRN-.YYYY.-.####\n",
      "reqd": 1
    },
    {
      "fieldname": "property",
      "fieldtype": "Link",
      "label": "Property",
      "options": "Property",
      "reqd": 1
    },
    {
      "fieldname": "guest_stay",
      "fieldtype": "Link",
      "label": "Guest Stay",
      "options": "Guest Stay",
      "reqd": true,
      "in_list_view": 1
    },
    {
      "fieldname": "room",
      "fieldtype": "Link",
      "label": "Room",
      "options": "Room",
      "fetch_from": "guest_stay.room",
      "read_only": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "col_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "transport_type",
      "fieldtype": "Select",
      "label": "Transport Type",
      "options": "\nAirport Pickup\nAirport Drop\nLocal Transfer\nCity Tour\nOther",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "pickup_datetime",
      "fieldtype": "Datetime",
      "label": "Pickup Date/Time",
      "reqd": 1
    },
    {
      "fieldname": "pickup_location",
      "fieldtype": "Data",
      "label": "Pickup Location"
    },
    {
      "fieldname": "drop_location",
      "fieldtype": "Data",
      "label": "Drop Location"
    },
    {
      "fieldname": "driver",
      "fieldtype": "Data",
      "label": "Driver"
    },
    {
      "fieldname": "status",
      "fieldtype": "Select",
      "label": "Status",
      "options": "Booked\nConfirmed\nCompleted\nCancelled",
      "default": "Booked",
      "in_list_view": 1
    }
  ],
  "permissions": [
    {
      "role": "Hotel Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1,
      "cancel": 1
    },
    {
      "role": "Hotel Receptionist",
      "read": 1,
      "write": 1,
      "create": 1,
      "submit": 1
    }
  ]
}