{
  "name": "Night Audit Run",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"NAR-.YYYY.-.####\n","reqd":1},
    {"fieldname":"property","fieldtype":"Link","label":"Property","options":"Property","reqd":1},
    {"fieldname":"audit_date","fieldtype":"Date","label":"Audit Date","reqd":1,"default":"Today","in_list_view":1},
    {"fieldname":"audit_status","fieldtype":"Select","label":"Status",
      "options":"Draft\nCompleted","default":"Draft","in_list_view":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"run_by","fieldtype":"Link","label":"Run By","options":"User","read_only":1},
    {"fieldname":"completed_at","fieldtype":"Datetime","label":"Completed At","read_only":1},
    {"fieldname":"sec_results","fieldtype":"Section Break","label":"Audit Results"},
    {"fieldname":"rooms_charged","fieldtype":"Int","label":"Rooms Charged","read_only":1},
    {"fieldname":"total_revenue","fieldtype":"Currency","label":"Room Revenue Posted","read_only":1},
    {"fieldname":"no_shows_flagged","fieldtype":"Int","label":"No-Shows Flagged","read_only":1},
    {"fieldname":"col2","fieldtype":"Column Break"},
    {"fieldname":"occupied_rooms","fieldtype":"Int","label":"Occupied Rooms","read_only":1},
    {"fieldname":"total_rooms","fieldtype":"Int","label":"Total Rooms","read_only":1},
    {"fieldname":"occupancy_pct","fieldtype":"Float","label":"Occupancy %","read_only":1},
    {"fieldname":"sec_forecast","fieldtype":"Section Break","label":"Tomorrow's Forecast"},
    {"fieldname":"expected_arrivals_tomorrow","fieldtype":"Int","label":"Expected Arrivals","read_only":1},
    {"fieldname":"expected_departures_tomorrow","fieldtype":"Int","label":"Expected Departures","read_only":1},
    {"fieldname":"sec_log","fieldtype":"Section Break","label":"Audit Log"},
    {"fieldname":"charge_log","fieldtype":"Long Text","label":"Charge Log (JSON)","read_only":1},
    {"fieldname":"notes","fieldtype":"Text","label":"Audit Notes"},
    {"fieldname":"amended_from","fieldtype":"Link","label":"Amended From","options":"Night Audit Run","print_hide":1}
  ],
  "permissions": [
    {"role":"Hotel Manager","read":1,"write":1,"create":1,"submit":1,"cancel":1,"amend":1},
    {"role":"Hotel Receptionist","read":1,"write":1,"create":1}
  ]
}
