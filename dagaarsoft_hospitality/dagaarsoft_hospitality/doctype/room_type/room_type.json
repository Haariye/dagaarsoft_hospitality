    {
      "fieldname": "sec_rates",
      "fieldtype": "Section Break",
      "label": "Rates"
    },
    {
      "fieldname": "rack_rate",
      "fieldtype": "Currency",
      "label": "Rack Rate"
    },
    {
      "fieldname": "bar_rate",
      "fieldtype": "Currency",
      "label": "Best Available Rate"
    },
    {
      "fieldname": "col_2",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "weekend_supplement",
      "fieldtype": "Currency",
      "label": "Weekend Supplement"
    },
    {
      "fieldname": "extra_bed_rate",
      "fieldtype": "Currency",
      "label": "Extra Bed Rate"
    },
    {
      "fieldname": "room_item",
      "fieldtype": "Link",
      "label": "ERPNext Charge Item",
      "options": "Item"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Is Active",
      "default": "1"
    }
  ],
  "permissions": [
    {
      "role": "Hotel Manager",
      "read": 1,
