      "options": "Property",
      "reqd": 1,
      "in_list_view": 1,
      "in_standard_filter": 1
    },
    {
      "fieldname": "col_1",
      "fieldtype": "Column Break"
    },
    {
      "fieldname": "max_occupancy",
      "fieldtype": "Int",
      "label": "Max Occupancy",
      "reqd": 1
    },
    {
      "fieldname": "bed_type",
      "fieldtype": "Select",
      "label": "Bed Type",
      "options": "\nSingle\nDouble\nTwin\nKing\nQueen\nSuite\nBunk"
    },
    {
      "fieldname": "room_size_sqm",
      "fieldtype": "Float",
      "label": "Room Size (sqm)"
