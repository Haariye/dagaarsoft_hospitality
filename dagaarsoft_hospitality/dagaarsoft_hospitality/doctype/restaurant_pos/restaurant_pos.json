{
  "name": "Restaurant POS",
  "doctype": "DocType",
  "module": "DagaarSoft Hospitality",
  "naming_rule": "By \"Naming Series\" field",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "track_changes": 1,
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"POS-.YYYY.-.####\n","reqd":1},
    {"fieldname":"order_type","fieldtype":"Select","label":"Order Type","options":"Dine In\nTakeaway\nRoom Service\nDelivery\nEvent\nBar","reqd":1,"default":"Dine In","in_list_view":1},
    {"fieldname":"property","fieldtype":"Link","label":"Property","options":"Property","reqd":1},
    {"fieldname":"outlet","fieldtype":"Link","label":"Outlet","options":"Outlet","reqd":1,"in_list_view":1},
    {"fieldname":"order_date","fieldtype":"Date","label":"Date","reqd":1,"in_list_view":1,"default":"Today"},
    {"fieldname":"order_time","fieldtype":"Time","label":"Time","reqd":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"order_status","fieldtype":"Select","label":"Status","options":"Draft\nOpen\nKOT Printed\nReady\nServed\nBilled\nPaid\nVoided","default":"Draft","in_list_view":1,"in_standard_filter":1},
    {"fieldname":"waiter","fieldtype":"Link","label":"Waiter","options":"User"},
    {"fieldname":"covers","fieldtype":"Int","label":"Covers","default":"1"},
    {"fieldname":"sec_table","fieldtype":"Section Break","label":"Table / Room"},
    {"fieldname":"restaurant_table","fieldtype":"Link","label":"Table","options":"Restaurant Table"},
    {"fieldname":"table_display","fieldtype":"Data","label":"Table No","read_only":1,"fetch_from":"restaurant_table.table_number"},
    {"fieldname":"col2","fieldtype":"Column Break"},
    {"fieldname":"room_number","fieldtype":"Link","label":"Room","options":"Room"},
    {"fieldname":"guest_stay","fieldtype":"Link","label":"Guest Stay","options":"Guest Stay","read_only":1},
    {"fieldname":"guest_name_display","fieldtype":"Data","label":"Guest Name","read_only":1},
    {"fieldname":"sec_customer","fieldtype":"Section Break","label":"Customer"},
    {"fieldname":"customer","fieldtype":"Link","label":"Customer","options":"Customer"},
    {"fieldname":"customer_name","fieldtype":"Data","label":"Customer Name"},
    {"fieldname":"col3","fieldtype":"Column Break"},
    {"fieldname":"mobile_no","fieldtype":"Data","label":"Mobile"},
    {"fieldname":"delivery_address","fieldtype":"Text","label":"Delivery Address"},
    {"fieldname":"sec_items","fieldtype":"Section Break","label":"Order Items"},
    {"fieldname":"items_json","fieldtype":"Long Text","label":"Items (JSON)","read_only":1,"description":"Managed by POS screen"},
    {"fieldname":"items_display","fieldtype":"HTML","label":"Order Summary"},
    {"fieldname":"sec_pricing","fieldtype":"Section Break","label":"Pricing"},
    {"fieldname":"subtotal","fieldtype":"Currency","label":"Subtotal","read_only":1},
    {"fieldname":"discount_type","fieldtype":"Select","label":"Discount Type","options":"\nPercentage\nFixed Amount"},
    {"fieldname":"discount_value","fieldtype":"Float","label":"Discount Value"},
    {"fieldname":"discount_amount","fieldtype":"Currency","label":"Discount Amount","read_only":1},
    {"fieldname":"col4","fieldtype":"Column Break"},
    {"fieldname":"tax_amount","fieldtype":"Currency","label":"Tax Amount","read_only":1},
    {"fieldname":"service_charge_pct","fieldtype":"Float","label":"Service Charge %","default":"0"},
    {"fieldname":"service_charge_amount","fieldtype":"Currency","label":"Service Charge","read_only":1},
    {"fieldname":"total_amount","fieldtype":"Currency","label":"Grand Total","read_only":1,"bold":1},
    {"fieldname":"sec_payment","fieldtype":"Section Break","label":"Payment"},
    {"fieldname":"payment_mode","fieldtype":"Select","label":"Payment Mode","options":"Cash\nCard\nBank Transfer\nRoom Charge\nCity Ledger\nComplimentary\nOnline"},
    {"fieldname":"amount_tendered","fieldtype":"Currency","label":"Amount Tendered"},
    {"fieldname":"change_amount","fieldtype":"Currency","label":"Change","read_only":1},
    {"fieldname":"col5","fieldtype":"Column Break"},
    {"fieldname":"paid_amount","fieldtype":"Currency","label":"Paid Amount","read_only":1},
    {"fieldname":"balance_due","fieldtype":"Currency","label":"Balance Due","read_only":1},
    {"fieldname":"sec_erp","fieldtype":"Section Break","label":"ERPNext Links"},
    {"fieldname":"sales_invoice","fieldtype":"Link","label":"Sales Invoice","options":"Sales Invoice","read_only":1},
    {"fieldname":"payment_entry","fieldtype":"Link","label":"Payment Entry","options":"Payment Entry","read_only":1},
    {"fieldname":"folio_charge_ref","fieldtype":"Data","label":"Folio Charge Ref","read_only":1},
    {"fieldname":"col6","fieldtype":"Column Break"},
    {"fieldname":"kot_reference","fieldtype":"Data","label":"KOT Reference","read_only":1},
    {"fieldname":"notes","fieldtype":"Text","label":"Order Notes"},
    {"fieldname":"kitchen_notes","fieldtype":"Text","label":"Kitchen Notes"},
    {"fieldname":"amended_from","fieldtype":"Link","label":"Amended From","options":"Restaurant POS","print_hide":1}
  ],
  "permissions": [
    {"role":"Hotel Manager","read":1,"write":1,"create":1,"submit":1,"cancel":1,"amend":1,"delete":1},
    {"role":"Restaurant Manager","read":1,"write":1,"create":1,"submit":1,"cancel":1,"amend":1},
    {"role":"Hotel Receptionist","read":1,"write":1,"create":1,"submit":1},
    {"role":"Hotel Cashier","read":1,"write":1,"submit":1}
  ]
}
