{
  "name": "RE Notice",
  "doctype": "DocType",
  "module": "DagaarSoft Real Estate",
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"RENTC-.YYYY.-.####","reqd":1},
    {"fieldname":"lease","fieldtype":"Link","label":"Lease","options":"RE Lease","reqd":1,"in_list_view":1},
    {"fieldname":"unit","fieldtype":"Link","label":"Unit","options":"RE Unit","in_list_view":1},
    {"fieldname":"tenant","fieldtype":"Link","label":"Tenant","options":"RE Tenant","in_list_view":1},
    {"fieldname":"notice_type","fieldtype":"Select","label":"Notice Type",
     "options":"Renewal Offer\nVacate Notice\nRent Increase\nLease Violation\nMaintenance Notice\nOther",
     "reqd":1,"in_list_view":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"notice_date","fieldtype":"Date","label":"Notice Date","reqd":1},
    {"fieldname":"effective_date","fieldtype":"Date","label":"Effective Date","reqd":1},
    {"fieldname":"status","fieldtype":"Select","label":"Status",
     "options":"Draft\nSent\nAcknowledged\nAccepted\nRejected\nExpired",
     "default":"Draft","in_list_view":1,"allow_on_submit":1},
    {"fieldname":"sec_content","fieldtype":"Section Break","label":"Notice Content"},
    {"fieldname":"new_rent_amount","fieldtype":"Currency","label":"New Rent Amount",
     "depends_on":"eval:doc.notice_type=='Rent Increase'"},
    {"fieldname":"new_end_date","fieldtype":"Date","label":"New End Date",
     "depends_on":"eval:doc.notice_type=='Renewal Offer'"},
    {"fieldname":"message","fieldtype":"Text Editor","label":"Notice Message","reqd":1},
    {"fieldname":"sec_resp","fieldtype":"Section Break","label":"Response"},
    {"fieldname":"tenant_response","fieldtype":"Select","label":"Tenant Response",
     "options":"\nAccepted\nRejected\nCounterOffer","allow_on_submit":1},
    {"fieldname":"response_date","fieldtype":"Date","label":"Response Date","allow_on_submit":1},
    {"fieldname":"response_notes","fieldtype":"Text","label":"Notes","allow_on_submit":1}
  ],
  "permissions": [{"role":"Hotel Manager","read":1,"write":1,"create":1,"delete":1,"submit":1,"cancel":1}],
  "track_changes": 1
}
