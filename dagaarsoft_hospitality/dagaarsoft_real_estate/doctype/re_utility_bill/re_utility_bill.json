{
  "name": "RE Utility Bill",
  "doctype": "DocType",
  "module": "DagaarSoft Real Estate",
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"REUTIL-.YYYY.-.####","reqd":1},
    {"fieldname":"lease","fieldtype":"Link","label":"Lease","options":"RE Lease","reqd":1,"in_list_view":1},
    {"fieldname":"unit","fieldtype":"Link","label":"Unit","options":"RE Unit","in_list_view":1},
    {"fieldname":"tenant","fieldtype":"Link","label":"Tenant","options":"RE Tenant","in_list_view":1},
    {"fieldname":"utility_type","fieldtype":"Select","label":"Utility",
     "options":"Water\nElectricity\nGas\nInternet\nWaste\nOther",
     "reqd":1,"in_list_view":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"bill_period","fieldtype":"Data","label":"Period","in_list_view":1},
    {"fieldname":"bill_date","fieldtype":"Date","label":"Bill Date","reqd":1},
    {"fieldname":"due_date","fieldtype":"Date","label":"Due Date"},
    {"fieldname":"sec_reading","fieldtype":"Section Break","label":"Meter Reading"},
    {"fieldname":"previous_reading","fieldtype":"Float","label":"Previous Reading"},
    {"fieldname":"current_reading","fieldtype":"Float","label":"Current Reading"},
    {"fieldname":"consumption","fieldtype":"Float","label":"Consumption","read_only":1},
    {"fieldname":"unit_rate","fieldtype":"Currency","label":"Rate per Unit"},
    {"fieldname":"col_reading","fieldtype":"Column Break"},
    {"fieldname":"bill_amount","fieldtype":"Currency","label":"Bill Amount","reqd":1},
    {"fieldname":"tenant_portion","fieldtype":"Currency","label":"Tenant Portion"},
    {"fieldname":"included_in_rent","fieldtype":"Check","label":"Included in Rent","default":"0"},
    {"fieldname":"sales_invoice","fieldtype":"Link","label":"Invoice","options":"Sales Invoice",
     "read_only":1,"allow_on_submit":1},
    {"fieldname":"notes","fieldtype":"Text","label":"Notes","allow_on_submit":1}
  ],
  "permissions": [{"role":"Hotel Manager","read":1,"write":1,"create":1,"delete":1,"submit":1,"cancel":1}],
  "track_changes": 1
}
