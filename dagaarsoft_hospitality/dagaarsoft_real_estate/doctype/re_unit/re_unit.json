{
  "name": "RE Unit",
  "doctype": "DocType",
  "module": "DagaarSoft Real Estate",
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "field_order": [
    "naming_series","unit_name","unit_number","property","unit_type","status",
    "col1",
    "floor","block","size_sqm","furnishing",
    "sec_rent",
    "monthly_rent","rent_includes_utility","currency",
    "col_rent",
    "security_deposit_amount","deposit_months","advance_months",
    "sec_utility",
    "utility_notes","water_included","electricity_included","gas_included","internet_included",
    "sec_asset",
    "fixed_asset","asset_value","construction_year",
    "col_asset",
    "has_watchman","watchman_name","watchman_phone","parking_slots",
    "sec_amenities",
    "amenities",
    "sec_meta",
    "current_tenant","current_lease","last_inspection_date",
    "col_meta",
    "is_active","notes","amended_from"
  ],
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"UNIT-.YYYY.-.####","reqd":1},
    {"fieldname":"unit_name","fieldtype":"Data","label":"Unit Name","reqd":1,"in_list_view":1,"bold":1},
    {"fieldname":"unit_number","fieldtype":"Data","label":"Unit No.","in_list_view":1},
    {"fieldname":"property","fieldtype":"Link","label":"Property","options":"RE Property","reqd":1,"in_list_view":1},
    {"fieldname":"unit_type","fieldtype":"Link","label":"Unit Type","options":"RE Unit Type","reqd":1,"in_list_view":1},
    {"fieldname":"status","fieldtype":"Select","label":"Status",
     "options":"Available\nOccupied\nReserved\nUnder Maintenance\nVacant - Cleaning\nOut of Service",
     "default":"Available","in_list_view":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"floor","fieldtype":"Int","label":"Floor"},
    {"fieldname":"block","fieldtype":"Data","label":"Block / Wing"},
    {"fieldname":"size_sqm","fieldtype":"Float","label":"Size (sqm)"},
    {"fieldname":"furnishing","fieldtype":"Select","label":"Furnishing",
     "options":"Furnished\nUnfurnished\nSemi-Furnished"},
    {"fieldname":"sec_rent","fieldtype":"Section Break","label":"Rent & Deposit"},
    {"fieldname":"monthly_rent","fieldtype":"Currency","label":"Monthly Rent","reqd":1},
    {"fieldname":"rent_includes_utility","fieldtype":"Check","label":"Rent Includes Utilities","default":"0"},
    {"fieldname":"currency","fieldtype":"Link","label":"Currency","options":"Currency"},
    {"fieldname":"col_rent","fieldtype":"Column Break"},
    {"fieldname":"security_deposit_amount","fieldtype":"Currency","label":"Security Deposit"},
    {"fieldname":"deposit_months","fieldtype":"Int","label":"Deposit (months)","default":"2"},
    {"fieldname":"advance_months","fieldtype":"Int","label":"Advance Rent (months)","default":"1"},
    {"fieldname":"sec_utility","fieldtype":"Section Break","label":"Utilities"},
    {"fieldname":"utility_notes","fieldtype":"Data","label":"Utility Notes"},
    {"fieldname":"water_included","fieldtype":"Check","label":"Water Included","default":"0"},
    {"fieldname":"electricity_included","fieldtype":"Check","label":"Electricity Included","default":"0"},
    {"fieldname":"gas_included","fieldtype":"Check","label":"Gas Included","default":"0"},
    {"fieldname":"internet_included","fieldtype":"Check","label":"Internet Included","default":"0"},
    {"fieldname":"sec_asset","fieldtype":"Section Break","label":"Asset & Building"},
    {"fieldname":"fixed_asset","fieldtype":"Link","label":"Fixed Asset","options":"Asset",
     "description":"Link to ERPNext Fixed Asset for depreciation tracking"},
    {"fieldname":"asset_value","fieldtype":"Currency","label":"Asset Value"},
    {"fieldname":"construction_year","fieldtype":"Int","label":"Year Built"},
    {"fieldname":"col_asset","fieldtype":"Column Break"},
    {"fieldname":"has_watchman","fieldtype":"Check","label":"Has Watchman","default":"0"},
    {"fieldname":"watchman_name","fieldtype":"Data","label":"Watchman Name",
     "depends_on":"eval:doc.has_watchman"},
    {"fieldname":"watchman_phone","fieldtype":"Data","label":"Watchman Phone","options":"Phone",
     "depends_on":"eval:doc.has_watchman"},
    {"fieldname":"parking_slots","fieldtype":"Int","label":"Parking Slots","default":"0"},
    {"fieldname":"sec_amenities","fieldtype":"Section Break","label":"Amenities & Inventory"},
    {"fieldname":"amenities","fieldtype":"Table","label":"Amenities","options":"RE Unit Amenity"},
    {"fieldname":"sec_meta","fieldtype":"Section Break","label":"Current Status"},
    {"fieldname":"current_tenant","fieldtype":"Link","label":"Current Tenant","options":"RE Tenant","read_only":1},
    {"fieldname":"current_lease","fieldtype":"Link","label":"Current Lease","options":"RE Lease","read_only":1},
    {"fieldname":"last_inspection_date","fieldtype":"Date","label":"Last Inspection","read_only":1},
    {"fieldname":"col_meta","fieldtype":"Column Break"},
    {"fieldname":"is_active","fieldtype":"Check","label":"Active","default":"1"},
    {"fieldname":"notes","fieldtype":"Text","label":"Notes"},
    {"fieldname":"amended_from","fieldtype":"Link","label":"Amended From","options":"RE Unit","print_hide":1}
  ],
  "permissions": [
    {"role":"Hotel Manager","read":1,"write":1,"create":1,"delete":1},
    {"role":"Hotel Receptionist","read":1,"write":1,"create":1}
  ],
  "title_field": "unit_name",
  "search_fields": "unit_name,unit_number,property",
  "track_changes": 1
}
