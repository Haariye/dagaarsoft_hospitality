    {"fieldname":"late_fee_grace_days","fieldtype":"Int","label":"Grace Days","default":"5"},
    {"fieldname":"sec_notify","fieldtype":"Section Break","label":"Notifications"},
    {"fieldname":"send_rent_reminder","fieldtype":"Check","label":"Send Rent Reminders","default":"1"},
    {"fieldname":"reminder_days_before","fieldtype":"Int","label":"Days Before Due","default":"3"},
    {"fieldname":"send_expiry_reminder","fieldtype":"Check","label":"Send Lease Expiry Reminder","default":"1"},
    {"fieldname":"expiry_reminder_days","fieldtype":"Int","label":"Days Before Expiry","default":"60"}
