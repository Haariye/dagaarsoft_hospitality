{
  "name": "RE Settings",
  "doctype": "DocType",
  "module": "DagaarSoft Real Estate",
  "engine": "InnoDB",
  "issingle": 1,
  "fields": [
    {"fieldname":"default_property","fieldtype":"Link","label":"Default Property","options":"RE Property"},
    {"fieldname":"rent_income_account","fieldtype":"Link","label":"Rent Income Account","options":"Account",
