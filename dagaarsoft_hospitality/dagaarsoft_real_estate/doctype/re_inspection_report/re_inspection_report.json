{
  "name": "RE Inspection Report",
  "doctype": "DocType",
  "module": "DagaarSoft Real Estate",
  "engine": "InnoDB",
  "autoname": "naming_series:",
  "is_submittable": 1,
  "fields": [
    {"fieldname":"naming_series","fieldtype":"Select","label":"Series","options":"REINSP-.YYYY.-.####","reqd":1},
    {"fieldname":"property","fieldtype":"Link","label":"Property","options":"RE Property","reqd":1,"in_list_view":1},
    {"fieldname":"unit","fieldtype":"Link","label":"Unit","options":"RE Unit","reqd":1,"in_list_view":1},
    {"fieldname":"inspection_type","fieldtype":"Select","label":"Type",
     "options":"Move-In\nMove-Out\nPeriodic\nMaintenance\nOther",
     "reqd":1,"in_list_view":1},
    {"fieldname":"inspection_date","fieldtype":"Date","label":"Date","reqd":1,"in_list_view":1},
    {"fieldname":"col1","fieldtype":"Column Break"},
    {"fieldname":"lease","fieldtype":"Link","label":"Lease","options":"RE Lease"},
    {"fieldname":"inspector","fieldtype":"Link","label":"Inspector","options":"User"},
    {"fieldname":"tenant_present","fieldtype":"Check","label":"Tenant Present","default":"1"},
    {"fieldname":"overall_condition","fieldtype":"Select","label":"Overall",
     "options":"Excellent\nGood\nFair\nPoor","in_list_view":1},
    {"fieldname":"sec_items","fieldtype":"Section Break","label":"Inspection Items"},
    {"fieldname":"items","fieldtype":"Table","label":"Items","options":"RE Inspection Item"},
    {"fieldname":"sec_summary","fieldtype":"Section Break","label":"Summary"},
    {"fieldname":"total_repair_cost","fieldtype":"Currency","label":"Total Repair Cost","read_only":1},
    {"fieldname":"deduct_from_deposit","fieldtype":"Check","label":"Deduct from Deposit","allow_on_submit":1},
    {"fieldname":"col_sum","fieldtype":"Column Break"},
    {"fieldname":"notes","fieldtype":"Text Editor","label":"Notes"},
    {"fieldname":"tenant_signature","fieldtype":"Signature","label":"Tenant Signature"},
    {"fieldname":"inspector_signature","fieldtype":"Signature","label":"Inspector Signature"}
  ],
  "permissions": [{"role":"Hotel Manager","read":1,"write":1,"create":1,"delete":1,"submit":1,"cancel":1}],
  "track_changes": 1
}
